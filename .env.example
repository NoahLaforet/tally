# Copy to .env and fill in. The .env file is gitignored and never committed.
# Everything here has a safe local default; you only need values you actually use.

# Passkey auth. Off by default (single local user, no login wall).
# Turn on for multi-user or remote access, and set a strong SESSION_SECRET.
AUTH_ENABLED=false
SESSION_SECRET=change-me-to-a-long-random-string
RP_ID=localhost
ORIGIN=http://127.0.0.1:8787

# Plaid live-sync (Wells Fargo + Chase). Get free dev keys at dashboard.plaid.com.
# Leave blank to keep statement-upload only.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional: Claude API key to categorize unknown merchants (only the merchant
# string is ever sent). Off unless USE_LLM_CATEGORIZER=true.
USE_LLM_CATEGORIZER=false
CLAUDE_API_KEY=

# First-run seeding: point these at a folder of statements and a budget-subs.js
# to populate the database. Defaults to backend/data/statements (gitignored).
TALLY_SEED_STATEMENTS=
TALLY_SEED_SUBS=
