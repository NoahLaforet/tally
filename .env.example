# Copy to .env in the REPO ROOT and fill in. The .env file is gitignored and
# never committed. Everything here has a safe local default; you only need
# values you actually use.

# ── Passkey auth ─────────────────────────────────────────────────────────────
# Off by default (single local user, no login wall). Turn on if the app is
# reachable beyond your own machine (e.g. served over Tailscale).
# With AUTH_ENABLED=true the server REFUSES to start until SESSION_SECRET is
# changed (generate one: openssl rand -hex 32). The first passkey registration
# needs the one-time setup code printed to the server console on startup.
AUTH_ENABLED=false
SESSION_SECRET=change-me-to-a-long-random-string

# The primary origin you open the app at. Passkeys are origin-bound and cannot
# be used on an IP origin, so use http://localhost:8787 locally, not 127.0.0.1.
ORIGIN=http://localhost:8787
# Comma-separated extra origins the app is also reachable on (e.g. your
# Tailscale HTTPS hostname). Each origin needs its own registered passkey.
EXTRA_ORIGINS=
# Set true when the app is served exclusively over HTTPS so the session cookie
# carries the Secure flag.
COOKIE_SECURE=false
# Absolute session lifetime in days.
SESSION_MAX_AGE_DAYS=14

# ── Plaid live-sync ──────────────────────────────────────────────────────────
# Optional. Get keys at dashboard.plaid.com; leave blank to stay upload-only.
# PLAID_ENV is sandbox or production (anything else refuses to run).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# OAuth banks (Chase, Wells Fargo) require an https redirect URI registered in
# the Plaid dashboard (Team Settings -> API -> Allowed redirect URIs).
PLAID_REDIRECT_URI=

# Written automatically the first time a Plaid token is stored; encrypts
# access tokens at rest in the database. Keep it with your other secrets.
# TALLY_ENCRYPTION_KEY=

# ── Alerts ───────────────────────────────────────────────────────────────────
# Pace warnings, unusual charges, subscription changes, and a weekly rollup.
# New alerts pop a macOS notification by default; set false to keep the in-app
# log without desktop banners.
ALERTS_NOTIFY=true
# The weekly rollup is also emailed once every field below is set (it stays off
# otherwise). Use an app password, not your account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DIGEST_TO=

# ── Misc ─────────────────────────────────────────────────────────────────────
# Reject uploads bigger than this many MB.
MAX_UPLOAD_MB=30

# Optional: Claude API key to categorize unknown merchants (only the merchant
# string is ever sent). Off unless USE_LLM_CATEGORIZER=true.
USE_LLM_CATEGORIZER=false
CLAUDE_API_KEY=

# First-run seeding: point these at a folder of statements to bulk-import on
# first launch. Defaults to empty (start with a clean database).
TALLY_SEED_STATEMENTS=
TALLY_SEED_SUBS=
